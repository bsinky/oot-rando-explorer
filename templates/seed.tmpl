<html>
    {{ template "head" }}
    <body>
        <h1>
            <a href="/">
            OOT Rando Explorer
        </a>
        </h1>
        <h2>Seed</h2>
        <h2 class="hash-icons-2x">
            {{ range fileHashIcons .FileHash }}
                <img src="{{.}}"/>
            {{end}}
        </h2>
        <a class="button download-button" href="/download/{{ .FileHash }}">Download</a>
        <div>Uploaded {{ .UploadTime }}</div>
        <div>{{ .Version }}</div>
        <div class="randoSettings">
            {{ .Logic }},
            Shopsanity {{ .Shopsanity }},
            Tokensanity {{ .Tokensanity }},
            Scrubsanity {{ .Scrubsanity }}
        </div>
        <div>
            <div>All settings:</div>
            <textarea class="raw-settings" disabled rows="30" cols="80">{{ .RawSettings }}</textarea>
        </div>
    </body>
</html>